{
  "name": "trinkhallen-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "trinkhallen.app — Cloudflare Workers + Hono app for finding German Trinkhallen / Spätis / Wasserhäuschen",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && tsx scripts/write-asset-manifest.ts && vite build",
    "preview": "wrangler dev",
    "cf:deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate:local": "wrangler d1 migrations apply trinkhallen-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply trinkhallen-prod --remote",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && pnpm db:migrate:local",
    "db:seed:local": "tsx scripts/seed-d1-local.ts",
    "db:seed:remote": "tsx scripts/seed-d1-local.ts --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/oauth-providers": "^0.6.0",
    "@protomaps/basemaps": "^5.7.2",
    "alpinejs": "^3.14.9",
    "hono": "^4.9.0",
    "htmx.org": "^2.0.4",
    "maplibre-gl": "^5.0.0",
    "opening_hours": "^3.8.0",
    "pmtiles": "^4.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@hono/vite-build": "^1.6.0",
    "@hono/vite-dev-server": "^0.20.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/alpinejs": "^3.13.11",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
