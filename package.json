{
  "name": "trinkhallen-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "trinkhallen.app — Cloudflare Workers + Hono app for finding German Trinkhallen / Spätis / Wasserhäuschen",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && bun scripts/write-asset-manifest.ts && bun scripts/import-data.ts && vite build",
    "build:data": "bun scripts/import-data.ts",
    "preview": "wrangler dev",
    "cf:deploy": "wrangler deploy --minify",
    "prepare": "lefthook install",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "db:migrate:local": "wrangler d1 migrations apply trinkhallen-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply trinkhallen-prod --remote",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && bun run db:migrate:local",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@fontsource/anton": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@hono/oauth-providers": "^0.6.0",
    "alpinejs": "^3.14.9",
    "fuse.js": "^7.3.0",
    "hono": "^4.9.0",
    "htmx.org": "^2.0.4",
    "maplibre-gl": "^5.0.0",
    "opening_hours": "^3.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@hono/vite-build": "^1.6.0",
    "@hono/vite-dev-server": "^0.20.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/alpinejs": "^3.13.11",
    "@types/bun": "^1.3.14",
    "@types/supercluster": "^7.1.3",
    "lefthook": "^2.1.8",
    "playwright": "^1.60.0",
    "supercluster": "^8.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0",
    "yaml": "^2.9.0"
  }
}
