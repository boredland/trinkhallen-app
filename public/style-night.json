{
  "version": 8,
  "name": "Trinkhallen Night",
  "$comment": "Minimal dark style. Uses MapLibre's public demo tiles for dev; swap `tiles` source to `pmtiles://https://r2.trinkhallen.app/de.pmtiles` once R2 is provisioned, and replace the layers with a proper Protomaps dark style.",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "osm-demo": {
      "type": "raster",
      "tiles": ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 19,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#0A0A0A" }
    },
    {
      "id": "osm",
      "type": "raster",
      "source": "osm-demo",
      "paint": {
        "raster-brightness-max": 0.55,
        "raster-saturation": -0.4,
        "raster-contrast": 0.1,
        "raster-opacity": 0.7
      }
    }
  ]
}
