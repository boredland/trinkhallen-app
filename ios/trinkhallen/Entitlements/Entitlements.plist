<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	v1 ships with no native entitlements. PWABuilder's template included
	aps-environment (Push Notifications) and associated-domains (Universal
	Links) by default — we don't use either yet, and their presence would
	require the provisioning profile to include matching capabilities,
	blocking the build. Add them back here AND on the bundle ID via
	`asc bundle-ids capabilities add` if/when we wire up push or want
	trinkhallen.app email links to open in the app instead of Safari.
	The macOS app-sandbox keys PWABuilder also seeded are no-ops on iOS;
	dropping them too keeps the surface honest.
	-->
</dict>
</plist>
